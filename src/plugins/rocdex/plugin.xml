<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    id="com.foxdebug.acode.rk.rocdex"
    version="1.0.1">
    <name>Rocdex</name>
    <description>Codex UI integration — manage and view Codex CLI web interface from Acode</description>

    <js-module name="Rocdex" src="www/Rocdex.js">
        <clobbers target="window.Rocdex" />
    </js-module>

    <platform name="android">
        <config-file parent="/*" target="res/xml/config.xml">
            <feature name="Rocdex">
                <param name="android-package" value="com.foxdebug.acode.rk.rocdex.RocdexPlugin" />
            </feature>
        </config-file>

        <source-file
            src="src/android/RocdexPlugin.java"
            target-dir="src/com/foxdebug/acode/rk/rocdex" />
    </platform>
</plugin>
